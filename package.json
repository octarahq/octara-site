{
  "name": "octara",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node -r dotenv/config -r tsconfig-paths/register --project tsconfig.server.json server.ts",
  "build": "next build",
  "start": "NODE_ENV=production ts-node -r dotenv/config -r tsconfig-paths/register --project tsconfig.server.json server.ts",
    "lint": "biome check",
    "format": "biome format --write",
    "prod": "git fetch && git reset --hard origin/main && git clean -fd && npm run build && npm run start"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.6.0",
    "@types/bcryptjs": "^2.4.6",
    "argon2": "^0.44.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "i18next": "^25.8.18",
    "jose": "^6.2.2",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sharp": "^0.34.5",
    "ws": "^8.13.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "tailwindcss": "^4",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5"
  }
}
